# ==============================================================================
# PAE Contable — Frontend Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and should NEVER be committed.
# ==============================================================================

# URL of the PAE Contable backend (FastAPI).
# Development default: http://localhost:8000
# Production: set to your deployed backend URL (e.g. https://api.paecontable.co)
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_COMPANY_NIT=800999888-10